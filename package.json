{
  "name": "o-melro-visitor-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env ELECTRON_DEV=true electron .\"",
    "electron:build": "tsc && vite build && electron-builder",
    "electron:start": "electron ."
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.344.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^6.22.3",
    "sqlite3": "^5.1.7",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/html2canvas": "*",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.4.2",
    "vite": "^5.1.5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.melro.visitor-management",
    "productName": "O Melro - Visitantes",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "goodbye-bird.jpeg",
        "to": "goodbye-bird.jpeg"
      },
      {
        "from": "already-exited-birds.jpeg",
        "to": "already-exited-birds.jpeg"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/logo.png",
      "uninstallerIcon": "public/logo.png"
    }
  }
}
